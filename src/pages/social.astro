---
import AutoVideo from "../components/AutoVideo.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { b } from "../utils/base";

const INSTAGRAM_URL = "https://www.instagram.com/drywallgangsters/";
const HANDLE = "@drywallgangsters";
---

<BaseLayout
  title="Follow @drywallgangsters — plastr Interior Linings"
  description="Follow plastr on Instagram @drywallgangsters. Behind the scenes, finished work, and everything in between across South East Queensland."
  keywords="drywallgangsters instagram, plastr instagram, plastering instagram, interior linings brisbane instagram"
>
  <Header solidNav />

  <main>
    <!-- ─── Full-screen video hero ─────────────────────── -->
    <section class="relative min-h-[100dvh] overflow-hidden flex flex-col">
      <AutoVideo
        src={`${b}/assets/hero-4.mp4`}
        class="absolute inset-0 w-full h-full object-cover"
      />

      <!-- Overlay -->
      <div class="absolute inset-0 bg-void/40 pointer-events-none"></div>
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: linear-gradient(to top, rgba(10,9,8,0.85) 0%, transparent 50%, rgba(10,9,8,0.25) 100%);"
      >
      </div>

      <!-- Centred content -->
      <div
        class="relative z-10 flex flex-col items-center justify-center flex-1 px-6 text-center pb-16 hero-content"
      >
        <!-- Instagram icon -->
        <div class="mb-6 hero-item" style="--i:0">
          <svg
            class="w-8 h-8 text-white/60 mx-auto"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path>
          </svg>
        </div>

        <!-- Handle -->
        <h1
          class="font-display font-bold text-white hero-item"
          style="font-size: clamp(2.5rem, 8vw, 6rem); line-height: 1; letter-spacing: -0.03em; --i:1"
        >
          {HANDLE}
        </h1>

        <!-- Tagline -->
        <p
          class="mt-5 text-sm sm:text-base text-white/75 max-w-sm leading-relaxed hero-item"
          style="--i:2"
        >
          Follow the work. Behind the scenes, finished projects, and everything
          in between — South East Queensland.
        </p>

        <!-- CTA -->
        <a
          href={INSTAGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-3 border border-white/30 text-white font-display font-bold px-8 py-4 text-sm tracking-widest uppercase transition-all duration-200 hover:bg-white hover:text-ink hero-item"
          style="--i:3"
        >
          Follow on Instagram
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>

      <!-- Scroll cue -->
      <div
        class="absolute bottom-16 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2"
      >
        <svg
          class="w-5 h-5 text-white/60 scroll-indicator"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
        </svg>
      </div>
    </section>

    <!-- ─── About the channel ──────────────────────────── -->
    <section class="bg-void py-24 sm:py-32">
      <div class="container-site">
        <div
          class="grid grid-cols-1 lg:grid-cols-[1fr_1fr] gap-16 lg:gap-24 items-center"
        >
          <!-- Left: copy -->
          <div>
            <p class="section-label-light mb-6 animate-on-scroll">
              <span class="w-5 h-px bg-white/20 inline-block align-middle"
              ></span>
              On Instagram
            </p>
            <h2
              class="text-display-md font-display font-bold text-white mb-6 animate-on-scroll"
              style="transition-delay: 0.1s;"
            >
              See the craft up close.
            </h2>
            <div
              class="space-y-4 text-white/75 text-sm leading-relaxed animate-on-scroll"
              style="transition-delay: 0.2s;"
            >
              <p>
                @drywallgangsters is where we document the work — tight details,
                before and afters, and the kind of finishes that take years to
                master.
              </p>
              <p>
                Follow along for real projects, real results, and a
                behind-the-scenes look at what sets Plastr apart from the rest.
              </p>
            </div>

            <a
              href={INSTAGRAM_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-10 inline-flex items-center gap-3 text-white font-display font-bold text-sm uppercase tracking-widest group animate-on-scroll"
              style="transition-delay: 0.3s;"
            >
              <svg
                class="w-5 h-5 text-white/50 group-hover:text-white transition-colors duration-200"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path>
              </svg>
              {HANDLE}
              <svg
                class="w-4 h-4 -ml-1 group-hover:translate-x-1 transition-transform duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
              </svg>
            </a>
          </div>

          <!-- Right: stat tiles -->
          <div
            class="grid-bordered grid-bordered-void grid grid-cols-2 animate-on-scroll"
            style="transition-delay: 0.2s;"
          >
            {
              [
                { value: "Real Work", label: "No studio setups" },
                { value: "SEQ", label: "South East Queensland" },
                { value: "On Site", label: "As it happens" },
                { value: "Follow", label: "Stay up to date" },
              ].map((item) => (
                <div class="p-8 flex flex-col gap-2">
                  <p class="font-display font-bold text-white text-lg">
                    {item.value}
                  </p>
                  <p class="text-xs font-display uppercase tracking-[0.18em] text-white/55">
                    {item.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Back to main site ──────────────────────────── -->
    <section class="bg-void border-t border-white/[0.06] py-16">
      <div
        class="container-site flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6"
      >
        <p class="text-sm text-white/55 max-w-sm">
          Ready to get a quote or discuss your project?
        </p>
        <a href={`${b}/`} class="btn-outline-light shrink-0">
          Back to Plastr
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  /* Staggered entrance for hero content items */
  .hero-item {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(0.2s + var(--i) * 0.15s);
  }

  @keyframes heroFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
