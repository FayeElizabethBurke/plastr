---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { b } from "../utils/base";

const FORMSPREE_ACTION = "https://formspree.io/f/YOUR_FORM_ID";
const PHONE = "07 0000 0000";
const PHONE_HREF = "tel:+61700000000";
---

<BaseLayout
  title="Get a Quote — plastr Interior Linings"
  description="Request a free quote from plastr Interior Linings. Residential and commercial plastering across Brisbane, Gold Coast, and South East Queensland."
  keywords="plastering quote Brisbane, free plaster quote, interior linings quote Brisbane, plasterer quote SEQ"
>
  <Header solidNav />

  <main class="bg-stone min-h-screen">

    <!-- Hero band -->
    <div class="bg-ink border-b border-white/[0.06]">
      <div class="container-site pt-36 pb-16 sm:pt-44 sm:pb-20">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6">
          <div>
            <p class="section-label-light mb-5 animate-on-scroll">
              <span class="text-white/25 font-bold mr-2">—</span> Get a Quote
            </p>
            <h1
              class="text-display-lg font-display font-bold text-white animate-on-scroll"
              style="transition-delay: 0.1s;"
            >
              Let's talk about<br />
              your project.
            </h1>
          </div>
          <p
            class="text-sm text-white/60 max-w-xs leading-relaxed animate-on-scroll sm:text-right"
            style="transition-delay: 0.2s;"
          >
            Free quotes on all residential and commercial<br class="hidden sm:block" />
            plastering across South East Queensland.
          </p>
        </div>
      </div>
    </div>

    <!-- Main content -->
    <div class="container-site py-16 sm:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-16 lg:gap-24">

        <!-- Left: contact details -->
        <div class="animate-on-scroll">

          <!-- Phone -->
          <div class="mb-10">
            <p class="text-xs font-display uppercase tracking-[0.22em] text-ash mb-3">
              Call us directly
            </p>
            <a
              href={PHONE_HREF}
              class="inline-flex items-center gap-3 text-ink font-display font-bold text-2xl tracking-tight hover:text-ash transition-colors duration-200 group"
              aria-label={`Call PLASTR on ${PHONE}`}
            >
              <svg
                class="w-5 h-5 text-dust group-hover:text-ash transition-colors duration-200"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
                />
              </svg>
              {PHONE}
            </a>
          </div>

          <!-- Service area -->
          <div class="mb-10 border-t border-dust pt-8">
            <p class="text-xs font-display uppercase tracking-[0.22em] text-ash mb-2">
              Service Area
            </p>
            <p class="text-sm text-ash leading-relaxed">
              Brisbane, Gold Coast, Sunshine Coast<br />
              and surrounds across South East Queensland.
            </p>
          </div>

          <!-- What to expect -->
          <div class="border-t border-dust pt-8">
            <p class="text-xs font-display uppercase tracking-[0.22em] text-ash mb-6">
              What to expect
            </p>
            <ul class="space-y-4">
              {[
                "Free, no-obligation quote",
                "Response within one business day",
                "Residential and commercial work",
                "Fixed-price where possible",
              ].map((item) => (
                <li class="flex items-start gap-3 text-sm text-ash">
                  <span class="mt-[3px] w-4 h-px bg-dust flex-shrink-0 inline-block"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>

        </div>

        <!-- Right: form -->
        <div class="animate-on-scroll" style="transition-delay: 0.15s;">
          <form
            action={FORMSPREE_ACTION}
            method="POST"
            id="contact-form"
            class="space-y-5"
            novalidate
          >
            <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value="New enquiry — PLASTR" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="form-name" class="form-label">Name *</label>
                <input
                  type="text"
                  id="form-name"
                  name="name"
                  required
                  placeholder="Your name"
                  class="form-input"
                  autocomplete="name"
                />
              </div>
              <div>
                <label for="form-phone" class="form-label">Phone *</label>
                <input
                  type="tel"
                  id="form-phone"
                  name="phone"
                  required
                  placeholder="0400 000 000"
                  class="form-input"
                  autocomplete="tel"
                />
              </div>
            </div>

            <div>
              <label for="form-suburb" class="form-label">Suburb / Location</label>
              <input
                type="text"
                id="form-suburb"
                name="suburb"
                placeholder="e.g. New Farm, Chermside"
                class="form-input"
                autocomplete="address-level2"
              />
            </div>

            <div>
              <label for="form-message" class="form-label">Project Details</label>
              <textarea
                id="form-message"
                name="message"
                rows="5"
                placeholder="Tell us about your project — type of work, size, timing..."
                class="form-input resize-none"
              ></textarea>
            </div>

            <div>
              <button
                type="submit"
                id="form-submit"
                class="btn-outline py-4 px-8"
              >
                Request a Quote
                <svg
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </button>
            </div>

            <div
              id="form-success"
              role="alert"
              class="hidden p-4 border border-dust text-ash text-sm font-body bg-stone-dark"
            >
              Thanks — we'll be in touch shortly to discuss your project.
            </div>

            <div
              id="form-error"
              role="alert"
              class="hidden p-4 border border-red-200 text-red-600 text-sm font-body bg-red-50"
            >
              Something went wrong. Please try again or call us directly.
            </div>
          </form>
        </div>

      </div>
    </div>

  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const successEl = document.getElementById("form-success");
  const errorEl = document.getElementById("form-error");
  const submitBtn = document.getElementById("form-submit") as HTMLButtonElement | null;

  const originalBtnHTML = submitBtn?.innerHTML ?? "";

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form) return;

    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
    }

    successEl?.classList.add("hidden");
    errorEl?.classList.add("hidden");

    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });

      if (res.ok) {
        form.reset();
        successEl?.classList.remove("hidden");
      } else {
        throw new Error("Submission failed");
      }
    } catch {
      errorEl?.classList.remove("hidden");
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalBtnHTML;
      }
    }
  });
</script>
