---
const stats = [
  { value: "30+", label: "Years Combined Experience" },
  { value: "500+", label: "Projects Delivered" },
  { value: "Res & Comm", label: "Specialist Capability" },
];
---

<section id="about" class="bg-stone py-24 sm:py-32 lg:py-40">
  <div class="container-site">

    <!-- Section label -->
    <p class="section-label mb-16 animate-on-scroll">
      <span class="text-dust font-bold mr-2">01 /</span> About
    </p>

    <!-- Two-column layout: decorative stat + body copy -->
    <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] gap-12 lg:gap-20 items-start">

      <!-- Left: oversized decorative number -->
      <div class="animate-on-scroll">
        <div
          class="text-stat font-display font-bold text-ink/[0.08] select-none leading-none"
          aria-hidden="true"
        >
          30+
        </div>
        <div class="-mt-4 sm:-mt-6">
          <p class="section-label text-ash">Years Combined Experience</p>
          <div class="w-8 h-px bg-dust my-6"></div>
          <p class="text-xs font-display uppercase tracking-[0.2em] text-ash">
            Brisbane & Surrounds
          </p>
        </div>
      </div>

      <!-- Right: headline + copy -->
      <div>
        <h2
          class="text-display-lg font-display font-bold text-ink mb-6 animate-on-scroll"
          style="transition-delay: 0.1s;"
        >
          Built on craft.<br />
          Driven by detail.
        </h2>
        <div
          class="space-y-5 text-ash leading-relaxed animate-on-scroll"
          style="transition-delay: 0.2s;"
        >
          <p>
            Plastr is brought to you by the team behind <span class="text-ink font-medium">@drywallgangsters</span> —
            tradespeople who've spent years setting the standard for interior plastering across South East Queensland.
          </p>
          <p>
            We excel in all aspects of interior plastering: from the finest residential finishes
            through to large-scale commercial linings. The same care, the same eye for detail,
            every single job.
          </p>
          <p>
            No shortcuts. No compromises. Just quality work — every time.
          </p>
        </div>
      </div>

    </div>

    <!-- Stats bar -->
    <div
      class="mt-20 pt-12 border-t border-dust grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-0 sm:divide-x sm:divide-dust"
    >
      {stats.map((stat, i) => (
        <div
          class={`animate-on-scroll sm:px-10 first:pl-0 last:pr-0`}
          style={`transition-delay: ${0.1 + i * 0.1}s;`}
        >
          <p class="font-display font-bold text-ink text-3xl sm:text-4xl tracking-tight mb-1">
            {stat.value}
          </p>
          <p class="text-xs font-display uppercase tracking-[0.18em] text-ash">
            {stat.label}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
