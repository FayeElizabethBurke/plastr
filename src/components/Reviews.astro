---
const reviews = [
  {
    name: "Sarah M.",
    location: "New Farm",
    text: "Absolute perfection. The team replastered our entire ground floor and the finish is flawless — you'd never know it wasn't original. Couldn't recommend them more highly.",
  },
  {
    name: "James T.",
    location: "Paddington",
    text: "Used plastr for a full commercial fitout. On time, on budget, and the quality of work was outstanding. Every wall came out perfectly level and smooth.",
  },
  {
    name: "Renee & Dan K.",
    location: "Coorparoo",
    text: "We were nervous about a big renovation but the plastr crew made it painless. Tidy, professional, and the results speak for themselves. Worth every cent.",
  },
  {
    name: "Marcus B.",
    location: "Chermside",
    text: "Called on a Wednesday, got a quote by Friday, work started the following Monday. Fast, fair, and the plastering is some of the cleanest I've seen in 20 years building.",
  },
];
---

<section id="reviews" class="bg-stone py-24 sm:py-32 lg:py-40 border-t border-ink/[0.06]">
  <div class="container-site">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-16 sm:mb-20">
      <div>
        <p class="section-label mb-5 animate-on-scroll">
          <span class="text-dust font-bold mr-2">04 /</span> Reviews
        </p>
        <h2
          class="text-display-lg font-display font-bold text-ink animate-on-scroll"
          style="transition-delay: 0.1s;"
        >
          What our<br />
          clients say.
        </h2>
      </div>

      <!-- Star rating summary -->
      <div class="flex flex-col gap-1 animate-on-scroll sm:items-end" style="transition-delay: 0.2s;">
        <div class="flex items-center gap-1" aria-label="5 out of 5 stars">
          {Array.from({ length: 5 }).map(() => (
            <svg class="w-5 h-5 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-xs font-display uppercase tracking-[0.2em] text-ash">5-star rated</p>
      </div>
    </div>

    <!-- Review cards -->
    <div class="-mx-4 sm:mx-0 overflow-x-auto overflow-y-hidden snap-x snap-mandatory">
      <div class="flex sm:grid sm:grid-cols-2 lg:grid-cols-4 gap-0.5 px-4 sm:px-0 pb-4 sm:pb-0">
      {reviews.map((review, i) => (
        <div
          class="flex-shrink-0 w-[80vw] sm:w-auto snap-start bg-ink/[0.04] p-8 flex flex-col gap-6 animate-on-scroll"
          style={`transition-delay: ${0.05 * i}s;`}
        >
          <!-- Stars -->
          <div class="flex items-center gap-0.5" aria-label="5 stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="w-3.5 h-3.5 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <!-- Quote -->
          <p class="text-sm text-ash leading-relaxed flex-1">
            "{review.text}"
          </p>

          <!-- Attribution -->
          <div class="border-t border-ink/[0.08] pt-5">
            <p class="text-sm font-display font-bold text-ink">{review.name}</p>
            <p class="text-xs text-dust mt-0.5">{review.location}</p>
          </div>
        </div>
      ))}
      </div>
    </div>

  </div>
</section>
