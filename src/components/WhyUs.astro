---
const pillars = [
  {
    number: "01",
    title: "Attention to Detail",
    description:
      "Every surface we touch is treated with precision. From seamless joins to perfectly level walls — the details are what separate a good finish from an outstanding one.",
  },
  {
    number: "02",
    title: "Proven Reliability",
    description:
      "We show up, we deliver, we follow through. No surprises, no chasing — just consistent, on-schedule work you can build your project around.",
  },
  {
    number: "03",
    title: "Total Professionalism",
    description:
      "From the first quote to the final coat, you deal with tradespeople who respect your time, your property, and your project as if it were their own.",
  },
  {
    number: "04",
    title: "Real Experience",
    description:
      "Decades of combined experience means we've worked across every project type. Nothing surprises us — and that confidence shows in everything we do.",
  },
];
---

<section id="why" class="bg-void py-24 sm:py-32 lg:py-40">
  <div class="container-site">

    <!-- Section header -->
    <div class="mb-16 sm:mb-20">
      <p class="section-label-light mb-5 animate-on-scroll">
        <span class="text-white/25 font-bold mr-2">04 /</span> Why Plastr
      </p>
      <h2
        class="text-display-lg font-display font-bold text-white max-w-lg animate-on-scroll"
        style="transition-delay: 0.1s;"
      >
        No shortcuts.<br />
        No excuses.
      </h2>
    </div>

    <!-- 4-pillar bordered grid on dark -->
    <div class="-mx-4 sm:mx-0 overflow-x-auto overflow-y-hidden snap-x snap-mandatory">
      <div class="flex sm:grid sm:grid-cols-2 lg:grid-cols-4 px-4 sm:px-0">
      {pillars.map((pillar, i) => (
        <div
          class="flex-shrink-0 w-[80vw] sm:w-auto snap-start bg-void p-8 sm:p-10 flex flex-col gap-5 animate-on-scroll border-r border-white/[0.08] last:border-r-0 sm:border-r-0 sm:border sm:border-white/[0.08]"
          style={`transition-delay: ${i * 0.1}s;`}
        >
          <!-- Number -->
          <span
            class="font-display font-bold text-white/10 select-none"
            style="font-size: 3.5rem; line-height: 1; letter-spacing: -0.04em;"
            aria-hidden="true"
          >
            {pillar.number}
          </span>

          <!-- Content -->
          <div>
            <h3 class="font-display font-bold text-white text-base mb-3">
              {pillar.title}
            </h3>
            <p class="text-sm text-white/80 leading-relaxed">
              {pillar.description}
            </p>
          </div>
        </div>
      ))}
      </div>
    </div>

  </div>
</section>
