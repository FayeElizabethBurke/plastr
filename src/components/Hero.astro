---
import { b } from '../utils/base';
import AutoVideo from './AutoVideo.astro';
---

<section id="hero" class="relative min-h-screen overflow-hidden flex flex-col">

  <!-- Background video -->
  <AutoVideo src={`${b}/assets/hero-2.mp4`} class="absolute inset-0 w-full h-full object-cover" />

  <!-- Overlays -->
  <div class="absolute inset-0 bg-void/20 pointer-events-none"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to top, rgba(10,9,8,0.82) 0%, rgba(10,9,8,0.1) 55%, rgba(10,9,8,0.25) 100%);"
  ></div>

  <!-- Content — bottom-left editorial layout -->
  <div class="relative z-10 flex flex-col justify-end flex-1 pb-20 sm:pb-24">
    <div class="container-site">

      <p class="hero-label" style="--delay: 0.1s">
        Interior Linings · South East Queensland
      </p>

      <h1 class="hero-wordmark" style="--delay: 0.25s">
        plastr
      </h1>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 right-8 sm:right-12 lg:right-16 z-10 flex items-center gap-3">
    <span class="text-[10px] font-display uppercase tracking-[0.3em] text-white/35">Scroll</span>
    <svg
      class="w-4 h-4 text-white/35 scroll-indicator"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>

</section>

<style>
  .hero-label {
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.75rem;
    opacity: 0;
    animation: heroUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  .hero-wordmark {
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: clamp(5rem, 14vw, 11.5rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: #ffffff;
    opacity: 0;
    animation: heroUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes heroUp {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

