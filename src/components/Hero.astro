---
// Hero uses hero.mp4 from the public root (served via publicDir: ../_plastr/assets)
---

<section id="hero" class="relative min-h-screen overflow-hidden flex flex-col">

  <!-- Background video -->
  <video
    id="hero-video"
    class="absolute inset-0 w-full h-full object-cover"
    autoplay
    muted
    loop
    playsinline
    preload="auto"
  >
    <source src="/hero.mp4" type="video/mp4" />
  </video>

  <!-- Overlay: subtle overall dim + strong bottom gradient for readability -->
  <div class="absolute inset-0 bg-void/30 pointer-events-none"></div>
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: linear-gradient(to top, rgba(10,9,8,0.80) 0%, rgba(10,9,8,0.05) 50%, rgba(10,9,8,0.35) 100%);"
  ></div>

  <!-- Content — centred -->
  <div class="relative z-10 flex flex-col items-center justify-center flex-1 px-6 text-center pb-20">

    <!-- Logo mark -->
    <div class="animate-fade mb-8" style="animation-delay: 0.1s; animation-fill-mode: both;">
      <img
        src="/logo-lg.jpg"
        alt="PLASTR"
        class="w-40 sm:w-52 mx-auto"
        style="filter: brightness(0) invert(1);"
        loading="eager"
      />
    </div>

    <!-- Tagline -->
    <p
      class="section-label-light tracking-[0.4em] animate-fade"
      style="animation-delay: 0.45s; animation-fill-mode: both;"
    >
      <span class="w-5 h-px bg-white/30 inline-block align-middle mr-3"></span>
      Precision Plastering · Brisbane
      <span class="w-5 h-px bg-white/30 inline-block align-middle ml-3"></span>
    </p>

  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
    <span class="text-[10px] font-display uppercase tracking-[0.3em] text-white/30">Scroll</span>
    <svg
      class="w-4 h-4 text-white/40 scroll-indicator"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
    </svg>
  </div>

</section>

<style>
  /* Ensure the fade animation plays correctly outside Tailwind */
  .animate-fade {
    opacity: 0;
    animation: fadeIn 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
</style>
