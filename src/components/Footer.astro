---
import { b } from "../utils/base";

const year = new Date().getFullYear();

const links = [
  { href: `${b}/#about`, label: "About" },
  { href: `${b}/#services`, label: "Services" },
  { href: `${b}/#work`, label: "Work" },
  { href: `${b}/social`, label: "Follow" },
  { href: `${b}/contact`, label: "Contact" },
];

const INSTAGRAM_URL = "https://www.instagram.com/drywallgangsters/";
---

<footer class="bg-void border-t border-white/[0.06] py-12 sm:py-16">
  <div class="container-site">
    <div
      class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8 pb-10 border-b border-white/[0.06]"
    >
      <!-- Brand -->
      <a href={`${b}/`} aria-label="plastr — Home" class="flex-shrink-0">
        <img
          src={`${b}/assets/logo_vector.svg`}
          alt="plastr Interior Linings"
          class="h-7 w-auto opacity-70 hover:opacity-100 transition-opacity duration-200"
          width="112"
          height="28"
          style="mix-blend-mode: screen;"
        />
      </a>

      <!-- Nav -->
      <nav
        aria-label="Footer navigation"
        class="flex flex-wrap gap-x-8 gap-y-3"
      >
        {
          links.map((link) => (
            <a
              href={link.href}
              class="text-xs font-display font-medium uppercase tracking-[0.18em] text-white/60 hover:text-white transition-colors duration-200"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Bottom bar -->
    <div
      class="pt-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-3"
    >
      <div class="flex flex-col gap-1">
        <p class="text-xs text-white/45">
          &copy; {year} Plastr Interior Linings. All rights reserved.
        </p>
        <a
          href="https://anchor-web.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-[11px] text-white/55 hover:text-white transition-colors duration-200"
        >
          Website by <span class="font-semibold">Anchor Websites</span>
        </a>
      </div>
      <a
        href={INSTAGRAM_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-xs text-white/45 hover:text-white transition-colors duration-200"
      >
        <svg
          class="w-3.5 h-3.5"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
          ></path>
        </svg>
        @drywallgangsters
      </a>
    </div>
  </div>
</footer>
