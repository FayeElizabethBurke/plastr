---
interface Props {
  src: string;
  class?: string;
}
const { src, class: className = "" } = Astro.props;

const id = `video-${Math.random().toString(36).slice(2)}`;
---

<video
  id={id}
  class={className}
  src={src}
  autoplay
  muted
  loop
  playsinline
  preload="auto"
></video>

<script>
  const el = document.getElementById("{id}");

  if (el instanceof HTMLVideoElement) {
    el.muted = true;

    const tryPlay = () => {
      el.play().catch(() => {
      });
    };
    tryPlay();

    el.addEventListener("loadeddata", tryPlay, { once: true });
    el.addEventListener("canplay", tryPlay, { once: true });
  }
</script>