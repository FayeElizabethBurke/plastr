---
interface Props {
  src: string;
  class?: string;
  pauseOffscreen?: boolean;
}
const { src, class: className = "", pauseOffscreen = false } = Astro.props;
---

<video
  class={className}
  autoplay
  muted
  loop
  playsinline
  preload="auto"
  data-autovideo
  data-pause-offscreen={pauseOffscreen ? "true" : undefined}
>
  <source src={src} type="video/mp4" />
  <track kind="captions" srclang="en" label="English" src="/plastr/assets/empty.vtt" default />
</video>

<script>
  function tryPlay(v: HTMLVideoElement) {
    v.muted = true;
    v.play().catch(() => {});
  }

  function initAll() {
    const videos = document.querySelectorAll<HTMLVideoElement>("video[data-autovideo]");

    videos.forEach((v) => {
      tryPlay(v);
      v.addEventListener("canplay", () => tryPlay(v), { once: true });

      if (v.dataset.pauseOffscreen === "true") {
        new IntersectionObserver(
          ([entry]) => {
            if (entry.isIntersecting) tryPlay(v);
            else v.pause();
          },
          { threshold: 0.1, rootMargin: "100px" }
        ).observe(v);
      }
    });

    // iOS gesture unlock — re-fire play on first touch
    document.addEventListener("touchstart", () => videos.forEach(tryPlay), { once: true, passive: true });
  }

  if (document.readyState === "complete") {
    initAll();
  } else {
    window.addEventListener("load", initAll);
  }
</script>
