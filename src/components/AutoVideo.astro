---
interface Props {
  src: string;
  class?: string;
}
const { src, class: className = "" } = Astro.props;
---

<video
  class={className}
  src={src}
  playsinline
  autoplay
  muted
  loop
  preload="auto"
  data-autovideo
  width="300px"
  height="300px"
></video>

<script is:inline>
  (function () {
    function playAll() {
      document.querySelectorAll("video[data-autovideo]").forEach(function (v) {
        v.muted = true;
        v.play().catch(function () {});
      });
    }

    // Try immediately — works on Android/desktop and some iOS
    playAll();

    // Re-try once any data is available on each video
    document.querySelectorAll("video[data-autovideo]").forEach(function (v) {
      v.addEventListener("canplay", function () {
        v.muted = true;
        v.play().catch(function () {});
      }, { once: true });
    });

    // iOS fallback: first touch/scroll unlocks media playback
    // ["touchstart", "touchend", "scroll"].forEach(function (evt) {
    //   document.addEventListener(evt, playAll, { once: true, passive: true });
    // });
  })();
</script>
